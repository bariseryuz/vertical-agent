# Ollama model — use a smaller one for speed (e.g. phi3:mini, llama3.2:1b, qwen2:0.5b)
# Pull first: ollama pull llama3.2:3b
SHIIMAN_MODEL=llama3.2:3b

# Server port
PORT=3000

# Optional: for search tool (Serper)
# https://serper.dev
SERPER_API_KEY=

# Optional: for Google Maps / Places verification
GOOGLE_MAPS_KEY=
